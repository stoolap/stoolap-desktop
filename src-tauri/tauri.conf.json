{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/.schemas/config.schema.json",
  "productName": "Stoolap Desktop",
  "identifier": "com.stoolap.desktop",
  "version": "0.4.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run vite:build",
    "beforeDevCommand": "npm run vite:dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Stoolap Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFENUE0NUI4NTE1QkQ2OTUKUldTVjFsdFJ1RVZhclg4aFdaZlRpSUIxUERBYVU1RzNjQ0I2ekVCYVJJZnlIUGthQy9hWW1ZY3MK",
      "endpoints": [
        "https://github.com/stoolap/stoolap-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
